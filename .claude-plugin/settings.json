{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Agent.*aws-investigator",
        "hooks": [
          {
            "type": "command",
            "command": "bash skills/aws-troubleshooting/run-investigation.sh \"${PROBLEM:-AWS issue detected}\" \"${AWS_PROFILE:-default}\" \"${AWS_DEFAULT_REGION:-us-east-1}\" \"${RESOURCE_NAME:-}\" 2>&1 | tail -50",
            "async": true,
            "statusMessage": "Running automated AWS service investigation..."
          }
        ]
      },
      {
        "matcher": "Agent.*eks-investigator",
        "hooks": [
          {
            "type": "command",
            "command": "bash skills/eks-troubleshooting/run-investigation.sh \"${PROBLEM:-Kubernetes issue detected}\" \"${CONTEXT:-}\" \"${NAMESPACE:-default}\" \"${RESOURCE_NAME:-}\" 2>&1 | tail -50",
            "async": true,
            "statusMessage": "Running automated EKS/Kubernetes investigation..."
          }
        ]
      },
      {
        "matcher": "Agent.*datadog-investigator",
        "hooks": [
          {
            "type": "command",
            "command": "bash skills/datadog-troubleshooting/run-investigation.sh \"${PROBLEM:-Datadog issue detected}\" \"${SERVICE_NAME:-}\" \"${ENVIRONMENT:-prod}\" \"${TIME_WINDOW:-60}\" 2>&1 | tail -50",
            "async": true,
            "statusMessage": "Running automated Datadog investigation..."
          }
        ]
      }
    ]
  }
}
